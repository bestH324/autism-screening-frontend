/* 个人中心页 */
.profile-header-card { display: flex; align-items: center; gap: 24rpx; background: #fff; border-radius: 20rpx; padding: 36rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06); }
.profile-avatar { width: 100rpx; height: 100rpx; line-height: 100rpx; text-align: center; font-size: 56rpx; background: var(--primary-lighter); border-radius: 50%; }
.profile-info { flex: 1; }
.profile-name { font-size: 36rpx; font-weight: 600; }
.profile-phone { font-size: 26rpx; color: var(--text-secondary); margin-top: 8rpx; }
.profile-arrow { font-size: 48rpx; color: var(--text-hint); }

.menu { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06); }
.menu-item { display: flex; align-items: center; gap: 20rpx; padding: 32rpx; border-bottom: 2rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 40rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-arrow { font-size: 40rpx; color: var(--text-hint); }
