/* 儿童管理页 */
.children-list { margin-bottom: 24rpx; }
.child-card {
  display: flex; align-items: center; gap: 20rpx;
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06);
}
.child-avatar { width: 88rpx; height: 88rpx; line-height: 88rpx; text-align: center; font-size: 48rpx; background: var(--primary-lighter); border-radius: 50%; }
.child-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.child-name { font-size: 32rpx; font-weight: 600; color: var(--text-primary); }
.child-detail { font-size: 26rpx; color: var(--text-secondary); }
.child-actions { display: flex; gap: 16rpx; }
.child-op { font-size: 40rpx; padding: 8rpx; }

.form-card { margin-top: 24rpx; }
.gender-selector { display: flex; gap: 20rpx; }
.gender-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  background: #fff; border: 2rpx solid #ECECEC; border-radius: 16rpx;
  font-size: 28rpx; color: var(--text-primary);
}
.gender-btn.selected { border-color: var(--primary); background: var(--primary-lighter); color: var(--primary); }
.gender-btn::after { border: none; }

.picker-display { line-height: 88rpx; color: var(--text-primary); }

.avatar-options { display: flex; flex-wrap: wrap; gap: 24rpx; }
.avatar-option {
  width: 84rpx; height: 84rpx; line-height: 84rpx; text-align: center;
  font-size: 44rpx; border-radius: 50%; border: 4rpx solid transparent; background: #f7f7f7;
}
.avatar-option.selected { border-color: var(--primary); background: var(--primary-lighter); }

.form-buttons { display: flex; gap: 20rpx; margin-top: 16rpx; }
.form-buttons .btn { flex: 1; }
