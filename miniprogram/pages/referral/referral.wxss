/* 转诊页 */
.intro { background: var(--primary-lighter); padding: 28rpx; border-radius: 16rpx; font-size: 26rpx; color: var(--primary-dark); line-height: 1.6; margin-bottom: 24rpx; }
.region-group { margin-bottom: 32rpx; }
.region-title { font-size: 32rpx; font-weight: 600; color: var(--primary); margin-bottom: 16rpx; }
.inst-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06); }
.inst-name { font-size: 32rpx; font-weight: 600; margin-bottom: 12rpx; }
.inst-tag { display: inline-block; background: var(--primary-lighter); color: var(--primary); font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 20rpx; margin-bottom: 16rpx; }
.inst-row { font-size: 28rpx; color: var(--text-secondary); line-height: 1.8; }
.inst-phone { color: var(--primary); }
.inst-desc { font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; margin-top: 12rpx; }
