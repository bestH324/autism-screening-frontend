/* 登录页 */
.login-logo { display: flex; flex-direction: column; align-items: center; margin: 40rpx 0 60rpx; }
.logo-circle { width: 120rpx; height: 120rpx; line-height: 120rpx; text-align: center; font-size: 64rpx; background: var(--primary-lighter); border-radius: 60rpx; }
.login-title { font-size: 36rpx; font-weight: 600; margin-top: 24rpx; color: var(--text-primary); }
.form-bottom { text-align: center; margin-top: 48rpx; font-size: 28rpx; color: var(--text-secondary); }
.link { color: var(--primary); margin-left: 8rpx; }
