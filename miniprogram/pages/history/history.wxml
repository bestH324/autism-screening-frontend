<!-- 历史记录页 -->
<view class="page-wrap">
  <view class="history-list" wx:if="{{list.length > 0}}">
    <view class="history-item" wx:for="{{list}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
      <view class="hi-header">
        <text class="hi-child">{{item.childAvatar || '👶'}} {{item.childName}}</text>
        <text class="hi-date">{{item.createTimeText}}</text>
      </view>
      <view class="hi-footer">
        <text class="risk-badge {{item.riskLevel}}">{{item.riskText}}</text>
        <text class="hi-score">得分：{{item.totalScore}}</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
    <text class="empty-icon">📋</text>
    <text>暂无筛查记录</text>
    <button class="btn btn-primary mt-20" bindtap="goScreening">去做筛查</button>
  </view>
</view>
