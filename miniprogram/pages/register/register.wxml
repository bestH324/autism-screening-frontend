<!-- 注册页 -->
<view class="page-wrap">
  <view class="form-group">
    <text class="form-label">手机号</text>
    <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
  </view>

  <view class="form-group">
    <text class="form-label">验证码</text>
    <view class="input-row">
      <input class="form-input flex-1" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
      <button class="btn btn-code" bindtap="sendCode" disabled="{{countdown > 0}}">
        {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
      </button>
    </view>
  </view>

  <view class="form-group">
    <text class="form-label">设置密码</text>
    <input class="form-input" type="password" maxlength="16" placeholder="请设置6-16位密码" value="{{password}}" bindinput="onPwdInput" />
  </view>

  <view class="form-group">
    <text class="form-label">确认密码</text>
    <input class="form-input" type="password" maxlength="16" placeholder="请再次输入密码" value="{{passwordConfirm}}" bindinput="onPwd2Input" />
  </view>

  <view class="agreement">
    <checkbox checked="{{agree}}" color="#6B1D5E" bindtap="toggleAgree" />
    <text class="agree-text">我已阅读并同意 </text>
    <text class="link" bindtap="showTerms">《用户服务协议》</text>
    <text class="agree-text"> 和 </text>
    <text class="link" bindtap="showPrivacy">《隐私政策》</text>
  </view>

  <button class="btn btn-primary btn-block" bindtap="doRegister" loading="{{loading}}">注册</button>

  <view class="form-bottom">
    <text>已有账号？</text>
    <text class="link" bindtap="goLogin">立即登录</text>
  </view>
</view>
