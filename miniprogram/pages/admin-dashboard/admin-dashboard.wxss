/* 管理员后台页 */
.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 24rpx; }
.stat-card { background: #fff; border-radius: 20rpx; padding: 32rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06); }
.stat-card.highlight { background: linear-gradient(135deg, #C0392B, #E74C3C); }
.stat-card.highlight .stat-num, .stat-card.highlight .stat-label { color: #fff; }
.stat-num { font-size: 52rpx; font-weight: 700; color: var(--primary); }
.stat-label { font-size: 24rpx; color: var(--text-secondary); margin-top: 8rpx; }

.chart-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.chart-label { width: 130rpx; font-size: 26rpx; color: var(--text-secondary); }
.chart-bar-wrap { flex: 1; height: 24rpx; background: #f0f0f0; border-radius: 12rpx; overflow: hidden; }
.chart-bar { height: 100%; border-radius: 12rpx; transition: width 0.4s; }
.bar-danger { background: linear-gradient(90deg, #E74C3C, #C0392B); }
.bar-warning { background: linear-gradient(90deg, #F39C12, #E67E22); }
.bar-safe { background: linear-gradient(90deg, #27AE60, #2ECC71); }
.bar-primary { background: linear-gradient(90deg, #6B1D5E, #8B3A7C); }
.chart-val { width: 60rpx; text-align: right; font-size: 26rpx; color: var(--text-primary); }

.tabs { display: flex; gap: 16rpx; margin: 24rpx 0; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; background: #fff; border-radius: 16rpx; font-size: 28rpx; color: var(--text-secondary); }
.tab.active { background: var(--primary); color: #fff; }

.data-table { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 16rpx rgba(107,29,94,0.06); }
.dt-row { display: flex; padding: 24rpx; border-bottom: 2rpx solid #f5f5f5; font-size: 26rpx; align-items: center; }
.dt-head { background: var(--primary-lighter); font-weight: 600; color: var(--primary); }
.flex05 { flex: 0.5; } .flex06 { flex: 0.6; } .flex08 { flex: 0.8; } .flex1 { flex: 1; } .flex12 { flex: 1.2; } .flex15 { flex: 1.5; }
.dt-empty { padding: 48rpx; text-align: center; color: var(--text-hint); font-size: 26rpx; }
