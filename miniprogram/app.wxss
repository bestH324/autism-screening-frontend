/* ============================================================
   星语 · 全局样式（南开紫主题，rpx 适配）
   ============================================================ */
page {
  --primary: #6B1D5E;
  --primary-light: #8B3A7C;
  --primary-lighter: #F3E8F0;
  --primary-dark: #4A1040;
  --text-primary: #2C3E50;
  --text-secondary: #7F8C8D;
  --text-hint: #BDC3C7;
  --bg-page: #F5F0F5;
  --bg-white: #FFFFFF;
  --danger: #E74C3C;
  --warning: #F39C12;
  --safe: #27AE60;

  background: var(--bg-page);
  color: var(--text-primary);
  font-size: 30rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  box-sizing: border-box;
}

view, text, button, input, textarea, image, scroll-view, video, picker { box-sizing: border-box; }

/* 通用容器 */
.page-wrap { min-height: 100vh; padding: 24rpx 28rpx 60rpx; }
.page-wrap.no-tab { padding-bottom: 60rpx; }

/* 卡片 */
.card {
  background: var(--bg-white);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(107, 29, 94, 0.06);
}
.card-title { font-size: 32rpx; font-weight: 600; margin-bottom: 20rpx; color: var(--text-primary); }

/* 按钮 */
.btn {
  display: flex; align-items: center; justify-content: center;
  height: 88rpx; line-height: 88rpx;
  border-radius: 44rpx; font-size: 32rpx; border: none;
  padding: 0 32rpx; margin: 0;
}
.btn::after { border: none; }
.btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-light)); color: #fff; }
.btn-outline { background: #fff; color: var(--primary); border: 2rpx solid var(--primary); }
.btn-wechat { background: #07C160; color: #fff; }
.btn-code { background: var(--primary-lighter); color: var(--primary); height: 72rpx; line-height: 72rpx; font-size: 26rpx; padding: 0 24rpx; border-radius: 12rpx; min-width: 200rpx; }
.btn-block { width: 100%; }
.btn[disabled] { opacity: 0.5; }
.mt-20 { margin-top: 40rpx; }
.mt-10 { margin-top: 20rpx; }

/* 表单 */
.form-group { margin-bottom: 32rpx; }
.form-label { display: block; font-size: 28rpx; color: var(--text-secondary); margin-bottom: 16rpx; }
.form-input {
  width: 100%; height: 88rpx; background: #fff;
  border: 2rpx solid #ECECEC; border-radius: 16rpx;
  padding: 0 24rpx; font-size: 30rpx; color: var(--text-primary);
}
.input-row { display: flex; align-items: center; gap: 16rpx; }
.flex-1 { flex: 1; }

/* 文本工具 */
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); font-size: 26rpx; }
.text-primary-c { color: var(--primary); }

/* 风险标签 */
.risk-badge { display: inline-block; padding: 6rpx 24rpx; border-radius: 24rpx; font-size: 26rpx; font-weight: 600; }
.risk-badge.low { background: #E8F8F0; color: #27AE60; }
.risk-badge.medium { background: #FEF5E7; color: #F39C12; }
.risk-badge.high { background: #FDEDEC; color: #E74C3C; }

/* 空状态 */
.empty-state { text-align: center; padding: 80rpx 0; color: var(--text-hint); }
.empty-state .empty-icon { font-size: 96rpx; margin-bottom: 20rpx; }

/* 隐藏 */
.hidden { display: none !important; }

/* 分割线文字 */
.divider-text { display: flex; align-items: center; text-align: center; color: var(--text-hint); font-size: 26rpx; margin: 40rpx 0; }
.divider-text::before, .divider-text::after { content: ''; flex: 1; height: 2rpx; background: #ECECEC; }
.divider-text text { padding: 0 24rpx; }
