.profile-header-card { background: #fff; border-radius: var(--radius); padding: 24px 16px; display: flex; align-items: center; margin-bottom: 16px; gap: 14px; }
.profile-header-card:active { opacity: 0.7; }
.profile-avatar { font-size: 48px; }
.profile-info { flex: 1; }
.profile-name { font-size: 18px; font-weight: 600; display: block; }
.profile-phone { font-size: 13px; color: var(--text-secondary); display: block; margin-top: 4px; }
.profile-arrow { font-size: 24px; color: var(--text-hint); }
.profile-menu { background: #fff; border-radius: var(--radius); overflow: hidden; margin-bottom: 20px; }
.menu-item { display: flex; align-items: center; padding: 16px; border-bottom: 1rpx solid var(--border); gap: 12px; }
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--bg-page); }
.menu-icon { font-size: 20px; }
.menu-text { flex: 1; font-size: 16px; }
.menu-arrow { font-size: 20px; color: var(--text-hint); }
