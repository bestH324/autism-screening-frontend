/* 启动页 */
page { background: var(--primary); }

.splash-container {
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    background: linear-gradient(135deg, #6B1D5E 0%, #8B3A7C 100%);
}

.splash-logo { text-align: center; margin-bottom: 60px; }
.logo-icon { font-size: 80px; display: block; }
.splash-title {
    font-size: 36px; font-weight: 700; color: #fff;
    display: block; margin-top: 16px;
}
.splash-subtitle {
    font-size: 16px; color: rgba(255,255,255,0.75);
    display: block; margin-top: 8px;
}

.splash-actions { width: 100%; max-width: 300px; display: flex; flex-direction: column; gap: 14px; }
.splash-actions .btn-outline { color: #fff; border-color: rgba(255,255,255,0.5); }

.splash-footer {
    position: absolute; bottom: 50px;
    font-size: 13px; color: rgba(255,255,255,0.5);
}
