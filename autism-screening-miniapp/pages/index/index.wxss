/* 首页样式 */
.banner-swiper { width: 100%; height: 320rpx; border-radius: var(--radius); overflow: hidden; margin-bottom: 16px; }
.banner-slide {
    height: 100%; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: linear-gradient(135deg, #6B1D5E, #8B3A7C);
    color: #fff; padding: 30px;
}
.banner-title { font-size: 22px; font-weight: 700; display: block; }
.banner-desc { font-size: 14px; opacity: 0.8; margin-top: 8px; display: block; }

.feature-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
.feature-card {
    background: #fff; border-radius: var(--radius); padding: 20px 16px;
    text-align: center; transition: all 0.2s;
}
.feature-card:active { transform: scale(0.96); background: var(--primary-lighter); }
.feature-icon { font-size: 36px; display: block; margin-bottom: 8px; }
.feature-name { font-size: 16px; font-weight: 600; color: var(--text-primary); display: block; }
.feature-desc { font-size: 12px; color: var(--text-secondary); margin-top: 4px; display: block; }

.section-card { background: #fff; border-radius: var(--radius); padding: 16px; margin-bottom: 16px; }
.section-title { font-size: 17px; font-weight: 600; margin-bottom: 12px; display: block; }
.quick-action-item {
    padding: 14px 0; border-bottom: 1rpx solid var(--border);
    font-size: 15px; display: flex; align-items: center; gap: 8px;
}
.quick-action-item:last-child { border-bottom: none; }
.quick-action-item:active { opacity: 0.6; }

.tips-card {
    background: var(--primary-lighter); border-radius: var(--radius);
    padding: 16px; display: flex; gap: 12px; align-items: flex-start;
}
.tips-icon { font-size: 24px; }
.tips-content { flex: 1; }
.tips-content text { font-size: 13px; color: var(--primary-dark); display: block; line-height: 1.6; }
